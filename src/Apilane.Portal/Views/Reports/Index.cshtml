@using Apilane.Portal.Models;
@using Apilane.Common.Models;
@model (DBWS_Application Application, List<DBWS_ReportPanel> Reports)

@{
    ViewBag.Title = "Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="clearfix">
    <div class="row">
        <div class="col-lg-12">
            <div class="page-header">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">@Model.Application.Server.Name</li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Applications")">Applications</a></li>
                        <li class="breadcrumb-item"><a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "Entities", appid = Model.Application.Token })">@Model.Application.Name</a></li>
                        <li class="breadcrumb-item active">Reports</li>
                    </ol>
                </nav>
            </div>

            @{
                await Html.RenderPartialAsync("~/Views/Application/OptionsPartial.cshtml", Model.Application);
            }

            <div class="mb-2">
                <a href="@Url.RouteUrl("AppRoute", new {controller = "Reports", action = "Create", appid = Html.GetAppToken() })" class="btn btn-primary"><i class="bi bi-plus me-1"></i>New report</a>
            </div>

            @Html.AntiForgeryToken()

            <div class="grid-stack">
                @foreach (var report in Model.Reports.OrderBy(x => x.Y).ThenBy(x => x.X))
                {
                    await Html.RenderPartialAsync("Report", (report, Model.Application, Model.Application.Token, Model.Application.Server.ServerUrl));
                }
            </div>
        </div>
    </div>
</div>

@section styles{
    <link rel="stylesheet" href="~/assets/vendor/gridstack/gridstack.min.css" />
    <style>
        .grid-stack { background: transparent; }
        .grid-stack-item-content { inset: 0; overflow: hidden; }
        .grid-report .card-body { padding: 0.75rem; }
    </style>
}

@section scripts{
    <script src="~/assets/vendor/chartjs/chart.umd.min.js"></script>
    <script src="~/assets/vendor/gridstack/gridstack-all.js"></script>
    <script type="text/javascript">

        var reportsGrid = GridStack.init({
            column: 12,
            cellHeight: 70,
            margin: 6,
            handle: '.report-drag-handle',
            float: false,
            resizable: { handles: 'e, se, s, sw, w' }
        });

        var saveLayoutUrl = '@Url.RouteUrl("AppRoute", new { controller = "Reports", action = "SaveLayout", appid = Model.Application.Token })';
        var antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        function saveReportsLayout() {
            var nodes = reportsGrid.save(false);
            var layout = nodes.map(function (n) {
                return { Id: parseInt(n.id, 10), X: n.x, Y: n.y, W: n.w, H: n.h };
            }).filter(function (n) { return n.Id > 0; });

            fetch(saveLayoutUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: JSON.stringify(layout)
            });
        }

        // Persist whenever the user moves or resizes a panel.
        reportsGrid.on('change', function () {
            saveReportsLayout();
        });

        // Chart.js (v2) only resizes on window resize, so nudge it when a panel is resized.
        reportsGrid.on('resizestop', function () {
            window.dispatchEvent(new Event('resize'));
        });

    </script>
}
