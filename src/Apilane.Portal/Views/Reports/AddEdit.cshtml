@using System.Linq
@using System.Text.Json
@using Apilane.Portal.Models;
@using Apilane.Common.Models;
@using Apilane.Common.Enums;
@using Apilane.Common.Utilities;
@model DBWS_ReportPanel

@{
    var IsEdit = Model != null && Model.ID > 0;

    ViewBag.Title = IsEdit ? "Edit" : "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";

    DBWS_Application Application = (DBWS_Application)ViewBag.Application;

    List<SelectListItem> ReportTypes = EnumProvider<ReportType>.GetValues(ReportType.Pie).Select(x => new SelectListItem { Text = x.Value, Value = x.Key.ToString() }).ToList();

    var timeRangeLabel = DBWS_ReportPanel.GetTimeRangeDisplay(Model?.TimeRange) ?? "None (top N)";

    List<DBWS_Entity> Entities = Application.Entities;

    var existingSeries = (Model?.Series ?? new List<DBWS_ReportSeries>())
        .OrderBy(s => s.Order)
        .Select(s => new { Label = s.Label, Entity = s.Entity, GroupBy = s.GroupBy, Property = s.Property, Filter = s.Filter ?? string.Empty })
        .ToList();
}

<div class="clearfix">
    <div class="row">
        <div class="col-lg-12">
            <div class="page-header">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">@Application.Server.Name</li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Applications")">Applications</a></li>
                        <li class="breadcrumb-item"><a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "Entities", appid = Application.Token })">@Application.Name</a></li>
                        <li class="breadcrumb-item"><a href="@Url.RouteUrl("AppRoute", new {controller = "Reports", action = "Index", appid = Application.Token })">Reports</a></li>
                        <li class="breadcrumb-item active">Report</li>
                    </ol>
                </nav>
            </div>
            <div class="row clearfix">
                <div class="col-12 col-xl-10">
                    <div class="card">
                        <h4 class="card-header">
                            @if (IsEdit)
                            {
                                @: Edit report '@Model?.Title'
                            }
                            else
                            {
                                @: New report
                            }
                        </h4>
                        <div class="card-body">
                            @using (Html.BeginRouteForm("AppRoute", new { controller = "Reports", action = (IsEdit ? "Edit" : "Create"), appid = Html.GetAppToken(), ReturnUrl = ViewBag.ReturnUrl, ID = (Model?.ID ?? 0) }, FormMethod.Post, true, new { role = "form" }))
                            {
                                @Html.HiddenFor(m => m.AppID)
                                <input type="hidden" name="seriesJson" id="seriesJson" />

                                <div class="row">
                                    <div class="form-group mb-3 col-md-6">
                                        <label class="form-label">Title</label>
                                        @Html.TextBoxFor(m => m.Title, new { @class = "form-control", placeholder = "Report title", autofocus = "autofocus" })
                                        @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="form-group mb-3 col-md-2">
                                        <label class="form-label">Visualization</label>
                                        @Html.DropDownListFor(m => m.TypeID, ReportTypes, null, new { @class = "form-select" })
                                        @Html.ValidationMessageFor(m => m.TypeID, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="form-group mb-3 col-md-2">
                                        <label class="form-label">Time range</label>
                                        @Html.HiddenFor(m => m.TimeRange)
                                        <button type="button" id="time-range-btn" class="btn btn-outline-secondary w-100 text-truncate d-flex align-items-center justify-content-between">
                                            <span id="time-range-label">@timeRangeLabel</span>
                                            <i class="bi bi-clock-history ms-1"></i>
                                        </button>
                                        <small class="text-muted">Date group-bys only.</small>
                                    </div>
                                    <div class="form-group mb-3 col-md-2">
                                        <label class="form-label">Max points per series</label>
                                        @Html.TextBoxFor(m => m.MaxRecords, new { @class = "form-control", placeholder = "Max points", type = "number", min = "1", max = "1000" })
                                        <small class="text-muted">Used when no time range.</small>
                                        @Html.ValidationMessageFor(m => m.MaxRecords, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <hr />
                                <label class="form-label">Series</label>
                                <p class="text-muted small mb-2">Each series is its own query and may target a different entity. For the overlay to line up, pick group-by values that are comparable across series (e.g. all grouped by the same date bucket).</p>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle" id="series-table">
                                        <thead>
                                            <tr>
                                                <th style="width:18%;">Label</th>
                                                <th style="width:18%;">Entity</th>
                                                <th style="width:20%;">Group by</th>
                                                <th style="width:20%;">Property</th>
                                                <th>Filter</th>
                                                <th style="width:40px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                                <button type="button" id="add-series" class="btn btn-sm btn-secondary mb-3"><i class="bi bi-plus me-1"></i>Add series</button>

                                <div class="form-group mb-3">
                                    @Html.ValidationMessage("CustomError", new { @class = "text-danger" })
                                </div>
                            }
                            <button type="button" class="btn_save btn btn-primary ignore-default-submit" title="@(IsEdit ? "Save" : "Create")">
                                <i class="bi bi-floppy"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/template" id="template-select">
    <ul id="sortable" class="list-group"></ul>
</script>

@section scripts{
    <script type="text/javascript">

        var existingSeries = @Html.Raw(Json.Serialize(existingSeries));
        var availableEntities = @Html.Raw(Json.Serialize(Entities.Select(e => e.Name).ToList()));

        function escapeAttr(v) { return (v || '').toString().replace(/&/g, '&amp;').replace(/"/g, '&quot;'); }

        // ---- Time-range selector ----
        function timeRangeDisplay(code) {
            if (!code) { return 'None (top N)'; }
            var n = parseInt(code, 10);
            var unit = code.slice(-1);
            var word = { h: 'hour', d: 'day', m: 'month', y: 'year' }[unit];
            if (!word || !n) { return 'None (top N)'; }
            return 'Last ' + n + ' ' + word + (n === 1 ? '' : 's');
        }

        function applyTimeRange(code) {
            $('#TimeRange').val(code || '');
            $('#time-range-label').text(timeRangeDisplay(code));
            Swal.close();
        }

        $('#time-range-btn').on('click', function () {
            var quick = [['', 'None (top N)'], ['24h', 'Last 24 hours'], ['7d', 'Last 7 days'], ['30d', 'Last 30 days'], ['90d', 'Last 90 days'], ['6m', 'Last 6 months']];
            for (var y = 1; y <= 3; y++) { quick.push([y + 'y', 'Last ' + y + ' year' + (y === 1 ? '' : 's')]); }

            var current = $('#TimeRange').val();
            var buttons = quick.map(function (q) {
                var cls = (q[0] === current) ? 'btn-primary' : 'btn-outline-secondary';
                return '<button type="button" class="btn btn-sm tr-quick ' + cls + '" data-code="' + q[0] + '">' + q[1] + '</button>';
            }).join(' ');

            Swal.fire({
                title: 'Time range',
                width: 540,
                showConfirmButton: false,
                showCancelButton: true,
                cancelButtonText: 'Cancel',
                html:
                    '<div class="text-start">' +
                    '<div class="fw-bold mb-1">Quick ranges</div>' +
                    '<div class="d-flex flex-wrap gap-1 mb-3">' + buttons + '</div>' +
                    '<div class="fw-bold mb-1">Custom</div>' +
                    '<div class="input-group input-group-sm">' +
                    '<span class="input-group-text">Last</span>' +
                    '<input id="tr-num" type="number" min="1" class="form-control" value="1" />' +
                    '<select id="tr-unit" class="form-select"><option value="h">hours</option><option value="d" selected>days</option><option value="m">months</option><option value="y">years</option></select>' +
                    '<button id="tr-custom-apply" class="btn btn-primary" type="button">Apply</button>' +
                    '</div></div>',
                didOpen: function () {
                    $('.tr-quick').on('click', function () { applyTimeRange('' + $(this).attr('data-code')); });
                    $('#tr-custom-apply').on('click', function () {
                        var n = parseInt($('#tr-num').val(), 10);
                        if (!n || n < 1) { return; }
                        applyTimeRange(n + $('#tr-unit').val());
                    });
                }
            });
        });

        function entityOptions(selected) {
            return availableEntities.map(function (e) {
                return '<option value="' + escapeAttr(e) + '"' + (e === selected ? ' selected' : '') + '>' + e + '</option>';
            }).join('');
        }

        function addSeriesRow(label, entity, groupBy, property, filter) {
            entity = entity || (availableEntities.length > 0 ? availableEntities[0] : '');
            var row = '<tr>' +
                '<td><input class="form-control form-control-sm series-label" value="' + escapeAttr(label) + '" placeholder="e.g. Paid" /></td>' +
                '<td><select class="form-select form-select-sm series-entity">' + entityOptions(entity) + '</select></td>' +
                '<td><input class="form-control form-control-sm series-groupby" value="' + escapeAttr(groupBy) + '" placeholder="group by" readonly style="cursor:pointer;" /></td>' +
                '<td><input class="form-control form-control-sm series-property" value="' + escapeAttr(property) + '" placeholder="e.g. ID.Count" readonly style="cursor:pointer;" /></td>' +
                '<td><input class="form-control form-control-sm series-filter" value="' + escapeAttr(filter) + '" placeholder="(no filter)" readonly style="cursor:pointer;" /></td>' +
                '<td class="text-center"><button type="button" class="btn btn-sm btn-link text-danger remove-series" title="Remove"><i class="bi bi-trash"></i></button></td>' +
                '</tr>';
            $('#series-table tbody').append(row);
        }

        $('#add-series').on('click', function () { addSeriesRow('', '', '', '', ''); });
        $('#series-table').on('click', '.remove-series', function () { $(this).closest('tr').remove(); });

        // Changing a row's entity invalidates its (entity-specific) group-by / property / filter.
        $('#series-table').on('change', '.series-entity', function () {
            var tr = $(this).closest('tr');
            tr.find('.series-groupby, .series-property, .series-filter').val('');
        });

        function rowEntity(el) { return $(el).closest('tr').find('.series-entity').val(); }

        $('#series-table').on('click', '.series-property', function () {
            var target = $(this);
            openPicker(rowEntity(this), true, function (selected) { target.val(selected.length ? selected[0] : ''); });
        });

        $('#series-table').on('click', '.series-groupby', function () {
            var target = $(this);
            openPicker(rowEntity(this), false, function (selected) { target.val(selected.join(',')); });
        });

        $('#series-table').on('click', '.series-filter', function () {
            var target = $(this);
            var entity = rowEntity(this);
            var existing = target.val();
            var url = '@Url.RouteUrl("AppRoute", new { controller = "Application", action = "UpdateFilterBuilder" })?EntityName=' + entity + '&ExistingFilter=' + encodeURIComponent(existing || '');
            Swal.fire({
                title: 'Series filter (' + entity + ')',
                width: 700,
                html: '<div id="series-filter-builder" class="text-start"></div>',
                showCancelButton: true,
                confirmButtonText: 'Apply',
                didOpen: function () { $('#series-filter-builder').load(url); },
                preConfirm: function () {
                    var f = getFilterObject();
                    return f.Filters.length > 0 ? JSON.stringify(f) : '';
                }
            }).then(function (res) {
                if (res.isConfirmed) { target.val(res.value || ''); }
            });
        });

        function openPicker(entity, isProperties, onConfirm) {
            if (!entity) { Swal.fire({ title: 'Select an entity first', confirmButtonText: 'OK' }); return; }
            var TypeID = $('#@nameof(DBWS_ReportPanel.TypeID)').val();
            var url = '@Url.RouteUrl("EntRoute", new { controller="Entity", action="GetProperties", appid=Application.Token, entid="PLACEHOLDER" })?typeID=' + TypeID;

            $.ajax({
                url: url.replace('PLACEHOLDER', entity),
                type: 'GET',
                success: function (data) {
                    var availableValues = (isProperties ? data.Properties : data.Groupings);
                    var properties = [];
                    $.each(availableValues, function (index, value) {
                        var prop = value.Name;
                        var html = '<li class="list-group-item">';
                        html += '<label class="custom-control custom-checkbox"><input type="checkbox" id="check-' + prop + '" class="check-property custom-control-input" data-id="' + (value.Subs.length == 0 ? prop : '') + '" data-sublist="sub-list-' + prop + '"/><span class="custom-control-label ms-2">' + prop + '</span></label>';
                        if (value.Subs.length > 0) {
                            html += '<ul style="list-style:none;display:none;" class="sub-list-list sub-list-' + prop + '">';
                            $.each(value.Subs, function (j, sub) {
                                html += '<li><label class="custom-control custom-checkbox"><input type="checkbox" id="check-' + prop + '-' + sub + '" class="check-sub custom-control-input" data-id="' + prop + '.' + sub + '"/><span class="custom-control-label ms-2">' + sub + '</span></label></li>';
                            });
                            html += '</ul>';
                        }
                        html += '</li>';
                        properties.push(html);
                    });

                    if (properties.length == 0) {
                        Swal.fire({ title: 'No properties found', text: 'This entity has no ' + (isProperties ? 'aggregatable properties' : 'group-by properties'), confirmButtonText: 'OK' });
                        return;
                    }

                    Swal.fire({
                        position: 'top',
                        title: isProperties ? 'Select a property to watch' : 'Select properties to group by',
                        html: $('#template-select').html(),
                        showCancelButton: true,
                        confirmButtonText: 'OK',
                        didOpen: function () {
                            $('#sortable').html(properties);
                            $('.check-property').on('change', function () {
                                $('.' + $(this).data().sublist).toggle('fast');
                                if (!this.checked) { $(this).closest('li').find('.check-sub').prop('checked', false); }
                                if (isProperties) {
                                    var that = this;
                                    $('.check-property').not(that).prop('checked', false);
                                    $('.check-property').not(that).each(function () { $('.' + $(this).data().sublist).hide(); });
                                    $('.check-sub').not($(that).closest('li').find('.check-sub')).prop('checked', false);
                                }
                            });
                            $('.check-sub').on('change', function () {
                                if (isProperties) {
                                    var that = this;
                                    $('.check-sub').not(that).prop('checked', false);
                                    $('.check-property').prop('checked', false);
                                }
                            });
                        },
                        preConfirm: function () {
                            var txt = [];
                            $.each($('.check-property:checked, .check-sub:checked'), function (i, el) {
                                var item = $(el).data().id;
                                if (item != null && ('' + item).trim() != '') { txt.push(item); }
                            });
                            return txt;
                        }
                    }).then(function (res) {
                        if (res.isConfirmed && res.value) { onConfirm(res.value); }
                    });
                }
            });
        }

        $('button.btn_save').on('click', function () {
            var series = [];
            var incomplete = false;
            $('#series-table tbody tr').each(function () {
                var label = $(this).find('.series-label').val();
                var entity = $(this).find('.series-entity').val();
                var groupBy = $(this).find('.series-groupby').val();
                var property = $(this).find('.series-property').val();
                var filter = $(this).find('.series-filter').val();
                if (!label && !groupBy && !property) { return; } // empty row, skip
                if (!label || !entity || !groupBy || !property) { incomplete = true; return; }
                series.push({ Label: label, Entity: entity, GroupBy: groupBy, Property: property, Filter: filter });
            });

            if (incomplete) {
                Swal.fire({ title: 'Incomplete series', text: 'Each series needs a label, entity, group-by and property.', confirmButtonText: 'OK' });
                return;
            }
            if (series.length === 0) {
                Swal.fire({ title: 'Add a series', text: 'Add at least one series.', confirmButtonText: 'OK' });
                return;
            }

            $('#seriesJson').val(JSON.stringify(series));
            $('button.btn_save').attr('disabled', true).html('<div class="spinner-border spinner-border-sm"><span class="visually-hidden">Loading...</span></div>');
            $('form').submit();
        });

        $(document).ready(function () {
            if (existingSeries && existingSeries.length > 0) {
                existingSeries.forEach(function (s) { addSeriesRow(s.Label, s.Entity, s.GroupBy, s.Property, s.Filter); });
            } else {
                addSeriesRow('', '', '', '', '');
            }
        });

    </script>
}

@section styles{
    <style>
        .series-groupby, .series-property, .series-filter { cursor: pointer; font-family: Consolas; }
        .list-group { height: 350px; overflow: auto; }
        .list-group-item { transition: unset !important; text-align: left !important; padding: 4px 0 0 12px; }
    </style>
}
