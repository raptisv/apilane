@using Apilane.Portal.Models;
@using Apilane.Common.Extensions;
@using Apilane.Common.Utilities;
@using Apilane.Common.Enums;
@using Apilane.Common.Models;
@using Apilane.Common;
@using Microsoft.AspNetCore.Http;
@model (List<DBWS_Application> Applications, List<DBWS_Server> Servers)
@{
    ViewBag.Title = "Applications";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isDarkTheme = Html.IsDarkTheme(Context.Request);
}

<div class="clearfix">
    <div class="row">
        <div class="col-lg-12">

            <div class="mb-4">
                <div class="btn-group" role="group" aria-label="Button group with nested dropdown">
                    <a href="@Url.Action("Create", "Applications")" class="btn btn-primary"><i class="bi bi-plus me-1"></i>New application</a>

                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop1" type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false"></button>
                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1" style="">
                            <a href="@Url.Action("Import", "Applications")" class="dropdown-item"><i class="bi bi-upload me-2"></i>Import</a>
                        </div>
                    </div>
                </div>                
            </div>

            @foreach (var server in Model.Servers)
            {
                if (Model.Applications.Any(x => x.ServerID == server.ID))
                {
                    <div class="mb-4 bg-body-tertiary d-flex justify-content-start align-items-center p-3 rounded-2">

                        <div class="card-header d-flex align-items-center">
                            <div class="online-indicator online-indicator-@server.ID">
                                <span class="blink"></span>
                            </div>
                            <div class="ms-3">
                                <a href="#" class="text-decoration-none btn-server-check-health" data-url="@(server.ServerUrl.ToLower().Trim('/'))">
                                    <h6 class="mb-0">@server.Name</h6>
                                </a>
                                <span class="text-muted fs-sm">@server.ServerUrl</span>
                            </div>
                        </div>
                    </div>

                    <div class="row clearfix">
                        @foreach (var app in Model.Applications.Where(x => x.ServerID == server.ID))
                        {
                            <div class='col-12 col-lg-4 col-md-6'>

                                <div class="card mb-4">

                                    <div class="card-header d-flex align-items-center">
                                        <span class="avatar text-bg-primary avatar-lg fs-5">@app.Name.ToUpper().First()</span>
                                        <div class="ms-3">
                                            <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "Entities", appid = app.Token })" class="text-decoration-none">
                                                <h6 class="mb-0">@app.Name</h6>
                                            </a>
                                            <span class="text-muted fs-sm">
                                                @(EnumProvider<DatabaseType>.GetDisplayValue(((DatabaseType)app.DatabaseType)))
                                            </span>
                                        </div>
                                        <div class="dropstart ms-auto">
                                            <button class="btn text-muted" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="i bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li>
                                                    <a href="#" class="dropdown-item swal-display-token-@app.ID">
                                                        <i class="bi bi-info-circle me-2"></i>Info
                                                    </a>
                                                </li>
                                                <li>
                                                    <a href="@(app.Server.ServerUrl.ToLower().Trim('/'))/swagger/index.html" class="dropdown-item" target="_blank">
                                                        <i class="bi bi-box-arrow-up-right me-2"></i>Swagger
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a href="#" class="dropdown-item compare-application-@app.Token">
                                                        <i class="bi bi-layout-split me-2"></i>Compare
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="card-body">                                        
                                        <ul class="list-group list-group-flush bg-transparent border-0">
                                            <li class="fs-sm list-group-item bg-transparent px-0">
                                                @if (app.Online)
                                                {
                                                    <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "SetStatus", appid = app.Token })" class="text-success text-decoration-none">
                                                        Online
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "SetStatus", appid = app.Token })" class="text-danger text-decoration-none">
                                                        Offline
                                                    </a>
                                                }
                                            </li>
                                            <li class="fs-sm list-group-item bg-transparent px-0">
                                                Differentiation
                                                @if (string.IsNullOrWhiteSpace(app.DifferentiationEntity))
                                                {
                                                    <span class="text-muted">none</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">@app.DifferentiationEntity</span>
                                                }
                                            </li>
                                            <li class="fs-sm list-group-item bg-transparent px-0">
                                                @if (app.UserID != User.Identity!.GetUserId())
                                                {
                                                    <text>
                                                        Shared by @app.AdminEmail
                                                    </text>
                                                }
                                                else
                                                {
                                                    <text>
                                                        Shared with @app.Collaborates.Count
                                                    </text>
                                                }
                                            </li>
                                        </ul>
                                    </div>                                    

                                    <div class="card-footer d-flex justify-content-between align-items-center">
                                        <div>
                                            <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "Entities", appid = app.Token })" class="btn btn-sm btn-default" title="Entities">
                                                <i class="bi bi-gear"></i>
                                            </a>
                                            <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "Security", appid = app.Token })" class="btn btn-sm btn-default" title="Security">
                                                <i class="bi bi-lock"></i>
                                            </a>
                                            <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "DataBrowser", appid = app.Token })" class="btn btn-sm btn-default" title="Data browser">
                                                <i class="bi bi-database"></i>
                                            </a>
                                            <div class="btn-group">
                                                <button class="btn btn-sm dropdown-toggle btn-default" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots"></i>
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new {controller = "CustomEndpoints", action = "Index", appid = app.Token })" class="dropdown-item">
                                                            <i class="bi bi-arrow-up-right-square me-2"></i>Custom
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "Email", appid = app.Token })" class="dropdown-item">
                                                            <i class="bi bi-envelope me-2"></i>Email
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new {controller = "Reports", action = "Index", appid = app.Token })" class="dropdown-item">
                                                            <i class="bi bi-graph-up me-2"></i>Reports
                                                        </a>
                                                    </li>
                                                    @if (app.UserID == User.Identity!.GetUserId())
                                                    {
                                                        <li>
                                                            <a href="@Url.RouteUrl("AppRoute", new { appid = app.Token, controller = "Collaborate", action = "Index" })" class="dropdown-item">
                                                                <i class="bi bi-people me-2"></i>Share
                                                            </a>
                                                        </li>
                                                    }
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new { appid = app.Token, controller = "Application", action = "Clone" })" class="dropdown-item">
                                                            <i class="bi bi-copy me-2"></i>Clone
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new { appid = app.Token, controller = "Application", action = "Rebuild" })" class="dropdown-item">
                                                            <i class="bi bi-wrench me-2"></i>Rebuild
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="#" class="dropdown-item export-application-@app.Token">
                                                            <i class="bi bi-cloud-arrow-down me-2"></i>Export
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "Edit", appid = app.Token })" class="dropdown-item">
                                                            <i class="bi bi-pen me-2"></i>Edit
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new {controller = "Application", action = "SetStatus", appid = app.Token })" class="dropdown-item">
                                                            <i class="@(app.Online ? "bi bi-lightbulb" : "bi bi-lightbulb-off") me-2"></i>@(app.Online ? "Go offline" : "Go online")
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="@Url.RouteUrl("AppRoute", new { appid = app.Token, controller = "Application", action = "Delete" })" class="dropdown-item">
                                                            <i class="bi bi-trash me-2"></i>Delete
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                        <div class="list-group-item storage_@app.ID" id="storage_@app.ID" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-original-title="Size on disk">
                                            <div class="spinner-border spinner-border-sm">
                                                <span class="visually-hidden">Loading...</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>


<div class="modal fade" id="modal-application-compare" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Application comparison</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div id="modal-application-compare-body" class="modal-body">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-subtle" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

@section scripts {
    <script type="text/javascript">

        function bindExportBtn(appToken, serverUrl) {
            $(`.export-application-${appToken}`).click(function () {
                $.ajax({
                    url: serverUrl + '/api/Application/Export',
                    type: 'GET',
                    beforeSend: function (request) {
                        request.setRequestHeader('Authorization', 'Bearer @Html.GetPortalUserAuthToken(User.Identity!)');
                        request.setRequestHeader('@Globals.ClientIdHeaderName', '@Globals.ClientIdHeaderValuePortal');
                        request.setRequestHeader('@Globals.ApplicationTokenHeaderName', appToken);
                    },
                    xhrFields: {
                        responseType: 'blob'
                    },
                    success: function (data) {
                        var a = document.createElement('a');
                        var url = window.URL.createObjectURL(data);
                        a.href = url;
                        a.download = `${appToken}.zip`;
                        document.body.append(a);
                        a.click();
                        a.remove();
                        window.URL.revokeObjectURL(url);
                    }
                });
            });
        }

        function bindCompareBtn(appToken, appName) {
            $(`.compare-application-${appToken}`).click(function () {
                // Build grouped options server-side (empty servers already excluded),
                // then strip the source app token from the list in JS.
                var allApps = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.Servers
                        .Where(s => Model.Applications.Any(x => x.ServerID == s.ID))
                        .ToDictionary(
                            k => k.Name,
                            v => Model.Applications
                                .Where(x => x.ServerID == v.ID)
                                .ToDictionary(k => k.Token, v => v.Name))));

                var filteredApps = {};
                Object.keys(allApps).forEach(function (serverName) {
                    var serverApps = {};
                    Object.keys(allApps[serverName]).forEach(function (token) {
                        if (token !== appToken) {
                            serverApps[token] = allApps[serverName][token];
                        }
                    });
                    if (Object.keys(serverApps).length > 0) {
                        filteredApps[serverName] = serverApps;
                    }
                });
                Swal.fire({
                    html: `Compare <b>${appName}</b> to:`,
                    input: 'select',
                    inputOptions: filteredApps,
                    inputPlaceholder: 'Select application',
                    showCancelButton: true,
                    confirmButtonText: 'Compare',
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: 'btn btn-primary',
                        cancelButton: 'btn',
                        input: 'form-control mx-auto my-8 w-75'
                    },
                    inputValidator: function (value) {
                        if (!value) return 'Please select an application to compare to';
                    },
                    preConfirm: function (value) {
                        return new Promise(function (resolve) {
                            compareApplications(appToken, value, resolve, function () {
                                Swal.showValidationMessage('Failed to load comparison data');
                            });
                        });
                    }
                }).then(function (result) {
                    if (result.isConfirmed && result.value) {
                        $('#modal-application-compare-body').html(buildDiffHtml(result.value));
                        $('#modal-application-compare').modal('show');
                    }
                });
            });
        }

        // Renders the comparison result into clean, scannable HTML.
        function buildDiffHtml(comparison) {

            function esc(str) {
                return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
            }
            function constraintTypeName(id) {
                return ({ 1: 'Unique', 2: 'Foreign Key' })[id] || ('Type ' + id);
            }

            var header = `<div class="d-flex align-items-center gap-2 mb-4 p-3 rounded-2 bg-body-tertiary">
                <span class="fw-semibold">${esc(comparison.ApplicationSource)}</span>
                <i class="bi bi-arrow-right text-muted"></i>
                <span class="fw-semibold">${esc(comparison.ApplicationTarget)}</span>
            </div>`;

            // Full entity card (used for Added and Removed)
            function entityFullCard(e) {
                var html = '<div class="card mb-2">';
                html += '<div class="card-header d-flex align-items-center gap-2">';
                html += '<span class="fw-semibold">' + esc(e.Name) + '</span>';
                if (e.Description) html += ' <span class="text-muted small">' + esc(e.Description) + '</span>';
                if (e.RequireChangeTracking)      html += ' <span class="badge bg-secondary">change tracking</span>';
                if (e.HasDifferentiationProperty) html += ' <span class="badge bg-info">differentiation</span>';
                html += '</div><div class="card-body p-0">';

                var props = e.Properties || [];
                var cons  = e.Constraints || [];

                if (props.length) {
                    html += '<table class="table table-sm mb-0">';
                    html += '<thead class="table-light"><tr><th>Property</th><th>Type</th><th>Required</th><th>Min</th><th>Max</th><th>Decimals</th><th>Encrypted</th><th>Regex</th><th>Description</th></tr></thead><tbody>';
                    props.forEach(function (p) {
                        html += '<tr>';
                        html += '<td class="fw-semibold">' + esc(p.Name) + '</td>';
                        html += '<td><span class="badge bg-secondary">' + esc(p.TypeLabel || p.Type || '') + '</span></td>';
                        html += '<td>' + (p.Required  ? '<i class="bi bi-check-circle-fill text-success"></i>' : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Minimum  != null ? p.Minimum  : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Maximum  != null ? p.Maximum  : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.DecimalPlaces != null ? p.DecimalPlaces : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Encrypted ? '<i class="bi bi-check-circle-fill text-success"></i>' : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.ValidationRegex ? '<code>' + esc(p.ValidationRegex) + '</code>' : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Description ? esc(p.Description) : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '</tr>';
                    });
                    html += '</tbody></table>';
                }

                if (cons.length) {
                    html += '<table class="table table-sm mb-0 border-top">';
                    html += '<thead class="table-light"><tr><th>Constraint</th><th>Properties</th></tr></thead><tbody>';
                    cons.forEach(function (c) {
                        html += '<tr><td><span class="badge bg-warning text-dark">' + constraintTypeName(c.TypeID) + '</span></td>';
                        html += '<td><code>' + esc(c.Properties || '') + '</code></td></tr>';
                    });
                    html += '</tbody></table>';
                }

                if (!props.length && !cons.length) {
                    html += '<div class="px-3 py-2 text-muted small">No user properties or constraints.</div>';
                }

                html += '</div></div>';
                return html;
            }

            // Changed entity card (properties/constraints added, removed, or field-level updates)
            function entityChangedCard(e) {
                var meta     = e.MetadataChanges   || [];
                var added    = e.PropertiesAdded   || [];
                var changed  = e.PropertiesChanged || [];
                var removed  = e.PropertiesRemoved || [];
                var cAdded   = e.ConstraintsAdded  || [];
                var cRemoved = e.ConstraintsRemoved || [];
                var html = '<div class="card mb-2"><div class="card-header fw-semibold">' + esc(e.Name) + '</div><div class="card-body p-0">';
                var hasPrev = false;

                // --- Entity metadata changes
                if (meta.length) {
                    html += '<div class="px-3 pt-2 pb-2"><span class="small fw-semibold text-warning"><i class="bi bi-pencil me-1"></i>Entity metadata changed</span>';
                    html += '<table class="table table-sm mt-1 mb-0"><thead class="table-light"><tr><th>Field</th><th>Before</th><th>After</th></tr></thead><tbody>';
                    meta.forEach(function (m) {
                        html += '<tr><td class="fw-semibold">' + esc(m.Field) + '</td>';
                        html += '<td><span class="text-danger">' + (m.Before != null ? esc(m.Before) : '<em class="text-muted">empty</em>') + '</span></td>';
                        html += '<td><span class="text-success">' + (m.After  != null ? esc(m.After)  : '<em class="text-muted">empty</em>') + '</span></td></tr>';
                    });
                    html += '</tbody></table></div>';
                    hasPrev = true;
                }

                // --- Properties added
                if (added.length) {
                    html += '<div class="px-3 pt-2 pb-1' + (hasPrev ? ' border-top' : '') + '"><span class="small fw-semibold text-success"><i class="bi bi-plus-circle me-1"></i>Properties added (' + added.length + ')</span></div>';
                    html += '<table class="table table-sm mb-0"><thead class="table-light"><tr><th>Property</th><th>Type</th><th>Required</th><th>Min</th><th>Max</th><th>Decimals</th><th>Encrypted</th><th>Regex</th><th>Description</th></tr></thead><tbody>';
                    added.forEach(function (p) {
                        html += '<tr>';
                        html += '<td class="fw-semibold">' + esc(p.Name) + '</td>';
                        html += '<td><span class="badge bg-secondary">' + esc(p.TypeLabel || p.Type || '') + '</span></td>';
                        html += '<td>' + (p.Required  ? '<i class="bi bi-check-circle-fill text-success"></i>' : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Minimum  != null ? p.Minimum  : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Maximum  != null ? p.Maximum  : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.DecimalPlaces != null ? p.DecimalPlaces : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Encrypted ? '<i class="bi bi-check-circle-fill text-success"></i>' : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.ValidationRegex ? '<code>' + esc(p.ValidationRegex) + '</code>' : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '<td>' + (p.Description ? esc(p.Description) : '<span class="text-muted">&mdash;</span>') + '</td>';
                        html += '</tr>';
                    });
                    html += '</tbody></table>';
                    hasPrev = true;
                }

                // --- Property field-level changes
                if (changed.length) {
                    html += '<div class="px-3 pt-2 pb-1' + (hasPrev ? ' border-top' : '') + '"><span class="small fw-semibold text-warning"><i class="bi bi-pencil me-1"></i>Properties updated (' + changed.length + ')</span></div>';
                    changed.forEach(function (p) {
                        html += '<div class="px-3 pb-1 small fw-semibold">' + esc(p.Name) + '</div>';
                        html += '<table class="table table-sm mb-0"><thead class="table-light"><tr><th>Field</th><th>Before</th><th>After</th></tr></thead><tbody>';
                        (p.Changes || []).forEach(function (ch) {
                            html += '<tr><td class="fw-semibold">' + esc(ch.Field) + '</td>';
                            html += '<td><span class="text-danger">' + (ch.Before != null ? esc(ch.Before) : '<em class="text-muted">empty</em>') + '</span></td>';
                            html += '<td><span class="text-success">' + (ch.After  != null ? esc(ch.After)  : '<em class="text-muted">empty</em>') + '</span></td></tr>';
                        });
                        html += '</tbody></table>';
                    });
                    hasPrev = true;
                }

                // --- Properties removed
                if (removed.length) {
                    html += '<div class="px-3 pt-2 pb-1' + (hasPrev ? ' border-top' : '') + '"><span class="small fw-semibold text-danger"><i class="bi bi-dash-circle me-1"></i>Properties removed (' + removed.length + ')</span></div>';
                    html += '<div class="px-3 pb-2 d-flex flex-wrap gap-1">';
                    removed.forEach(function (p) {
                        html += '<span class="badge bg-danger-subtle text-danger fw-normal">' + esc(p.Name) + ' <span class="opacity-75">' + esc(p.TypeLabel || p.Type || '') + '</span></span>';
                    });
                    html += '</div>';
                    hasPrev = true;
                }

                // --- Constraints added
                if (cAdded.length) {
                    html += '<div class="px-3 pt-2 pb-1' + (hasPrev ? ' border-top' : '') + '"><span class="small fw-semibold text-success"><i class="bi bi-plus-circle me-1"></i>Constraints added</span></div>';
                    html += '<table class="table table-sm mb-0"><thead class="table-light"><tr><th>Constraint</th><th>Properties</th></tr></thead><tbody>';
                    cAdded.forEach(function (c) {
                        html += '<tr><td><span class="badge bg-warning text-dark">' + constraintTypeName(c.TypeID) + '</span></td><td><code>' + esc(c.Properties || '') + '</code></td></tr>';
                    });
                    html += '</tbody></table>';
                    hasPrev = true;
                }

                // --- Constraints removed
                if (cRemoved.length) {
                    html += '<div class="px-3 pt-2 pb-1' + (hasPrev ? ' border-top' : '') + '"><span class="small fw-semibold text-danger"><i class="bi bi-dash-circle me-1"></i>Constraints removed</span></div>';
                    html += '<table class="table table-sm mb-0"><thead class="table-light"><tr><th>Constraint</th><th>Properties</th></tr></thead><tbody>';
                    cRemoved.forEach(function (c) {
                        html += '<tr><td><span class="badge bg-warning text-dark">' + constraintTypeName(c.TypeID) + '</span></td><td><code>' + esc(c.Properties || '') + '</code></td></tr>';
                    });
                    html += '</tbody></table>';
                }

                html += '</div></div>';
                return html;
            }

            // Custom endpoint cards
            function ceCard(ce) {
                var html = '<div class="py-2">';
                html += '<span class="fw-semibold">' + esc(ce.Name) + '</span>';
                if (ce.Description) html += ' <span class="text-muted small">' + esc(ce.Description) + '</span>';
                html += '<div class="mt-1"><code class="text-wrap">' + esc(ce.Query) + '</code></div>';
                html += '</div>';
                return html;
            }
            function ceChangedCard(ce) {
                var html = '<div class="py-2"><span class="fw-semibold">' + esc(ce.Name) + '</span><div class="mt-1 small">';
                if (ce.DescriptionBefore !== ce.DescriptionAfter) {
                    html += '<div><span class="fw-semibold">Description:</span> <span class="text-danger">' + (ce.DescriptionBefore ? esc(ce.DescriptionBefore) : '<em class="text-muted">empty</em>') + '</span>';
                    html += ' &rarr; <span class="text-success">' + (ce.DescriptionAfter ? esc(ce.DescriptionAfter) : '<em class="text-muted">empty</em>') + '</span></div>';
                }
                if (ce.QueryBefore !== ce.QueryAfter) {
                    html += '<div><span class="fw-semibold">Query before:</span> <code>' + esc(ce.QueryBefore) + '</code></div>';
                    html += '<div><span class="fw-semibold">Query after:</span> <code>' + esc(ce.QueryAfter) + '</code></div>';
                }
                html += '</div></div>';
                return html;
            }

            // Security items
            function secItem(s) {
                var meta = [s.Role, s.Action, s.Record].filter(Boolean).join(' &middot; ');
                if (s.RateLimit && s.RateLimit !== 'none') meta += ' &middot; limit: ' + s.RateLimit;
                return '<div class="py-1"><span class="fw-semibold">' + esc(s.Name) + '</span><span class="text-muted small ms-2">' + meta + '</span></div>';
            }
            function secChangedItem(s) {
                function diff(label, before, after) {
                    return before !== after
                        ? label + ': <span class="text-danger">' + esc(before) + '</span>&nbsp;&rarr;&nbsp;<span class="text-success">' + esc(after) + '</span>'
                        : null;
                }
                var diffs = [
                    diff('Role',       s.SecurityBefore.Role,       s.SecurityAfter.Role),
                    diff('Action',     s.SecurityBefore.Action,     s.SecurityAfter.Action),
                    diff('Record',     s.SecurityBefore.Record,     s.SecurityAfter.Record),
                    diff('RateLimit',  s.SecurityBefore.RateLimit,  s.SecurityAfter.RateLimit),
                    diff('Properties', s.SecurityBefore.Properties, s.SecurityAfter.Properties)
                ].filter(Boolean);
                return '<div class="py-1"><span class="fw-semibold">' + esc(s.Name) + '</span>' + (diffs.length ? '<div class="text-muted small mt-1">' + diffs.join(' &bull; ') + '</div>' : '') + '</div>';
            }

            var entSection = buildDiffSection(
                'grid-3x3', 'Entities',
                comparison.Entities.Added   || [],
                comparison.Entities.Removed || [],
                comparison.Entities.Changed || [],
                entityFullCard, entityFullCard, entityChangedCard
            );

            var ceSection = buildDiffSection(
                'arrow-up-right-square', 'Custom Endpoints',
                comparison.CustomEndpoints.Added   || [],
                comparison.CustomEndpoints.Removed || [],
                comparison.CustomEndpoints.Changed || [],
                ceCard, ceCard, ceChangedCard
            );

            var secSection = buildDiffSection(
                'lock', 'Security',
                comparison.Security.Added   || [],
                comparison.Security.Removed || [],
                comparison.Security.Changed || [],
                secItem, secItem, secChangedItem
            );

            var sections = (entSection || '') + (ceSection || '') + (secSection || '');

            if (!sections) {
                return header + '<div class="text-center py-4 text-muted">' +
                    '<i class="bi bi-check-circle fs-3 d-block mb-2 text-success"></i>' +
                    'Applications are identical</div>';
            }

            return header + sections;
        }

        // Builds one section (Entities / Custom Endpoints / Security) of the diff view.
        function buildDiffSection(icon, title, added, removed, changed, addedFn, removedFn, changedFn) {
            if (!added.length && !removed.length && !changed.length) return '';

            var html = '<div class="mb-4">' +
                '<div class="d-flex align-items-center gap-2 mb-2 pb-1 border-bottom">' +
                    '<i class="bi bi-' + icon + ' text-muted"></i>' +
                    '<span class="fw-semibold">' + title + '</span>' +
                '</div>';

            if (added.length) {
                html += '<div class="mb-2">' +
                    '<span class="small fw-semibold text-success"><i class="bi bi-plus-circle me-1"></i>Added (' + added.length + ')</span>' +
                    '<div class="ps-3 border-start border-2 border-success mt-1">' + added.map(addedFn).join('') + '</div>' +
                    '</div>';
            }

            if (removed.length) {
                html += '<div class="mb-2">' +
                    '<span class="small fw-semibold text-danger"><i class="bi bi-dash-circle me-1"></i>Removed (' + removed.length + ')</span>' +
                    '<div class="ps-3 border-start border-2 border-danger mt-1">' + removed.map(removedFn).join('') + '</div>' +
                    '</div>';
            }

            if (changed.length) {
                html += '<div class="mb-2">' +
                    '<span class="small fw-semibold text-warning"><i class="bi bi-pencil me-1"></i>Changed (' + changed.length + ')</span>' +
                    '<div class="ps-3 border-start border-2 border-warning mt-1">' + changed.map(changedFn).join('') + '</div>' +
                    '</div>';
            }

            html += '</div>';
            return html;
        }

        function compareApplications(appTokenSource, appTokenTarget, callback, errorCallback) {
            $.ajax({
                url: `@Url.Action("CompareApplications", "Applications")?appTokenSource=${appTokenSource}&appTokenTarget=${appTokenTarget}`,
                type: 'GET',
                dataType: 'json',
                contentType: 'application/json; charset=utf-8',
                success: function (data) {
                    if (callback) callback(data);
                },
                error: function (e) {
                    if (errorCallback) errorCallback(e);
                    else handleCustomError(e);
                }
            });
        }

        function loadApplicationStorageUsed(appId, appToken, serverUrl) {
            $.ajax({
                url: serverUrl + '/api/Application/GetStorageUsed',
                type: 'GET',
                beforeSend: function (request) {
                    request.setRequestHeader('Authorization', 'Bearer @Html.GetPortalUserAuthToken(User.Identity!)');
                    request.setRequestHeader('@Globals.ClientIdHeaderName', '@Globals.ClientIdHeaderValuePortal');
                    request.setRequestHeader('@Globals.ApplicationTokenHeaderName', appToken);
                },
                success: function (storageUsed) {
                    $('.storage_' + appId).show();
                    $('#storage_' + appId).html(getValueAsMBorGB(storageUsed));
                },
                error: function (e) {
                    $('.storage_' + appId).show();
                    var js = getErrorJSON(e);
                    var message = js !== null && js.Message && js.Message !== null
                        ? js.Message
                        : 'Error';
                    $('#storage_' + appId).html('<div style="color:red;">' + message + '</div>');
                }
            });
        }

        function bindServerHealthLink() {

            $('.btn-server-check-health').click(function(){
                var url = $(this).data().url;

                Swal.fire({
                    icon: "info",
                    title: "Checking server...",
                    text: url,
                    confirmButtonText: 'OK',
                    showCancelButton: false,
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: 'btn btn-primary',
                        cancelButton: 'btn'
                    },
                    didOpen: () => {
                        Swal.showLoading();
                        $.ajax({
                            url: `${url}/Health/Liveness`,
                            type: 'GET',
                            dataType: 'json',
                            contentType: 'application/json; charset=utf-8',
                            success: function (stats) {
                                Swal.hideLoading();
                                Swal.update({
                                    icon: 'success',
                                    title: "Server is healthy",
                                })
                            },
                            error: function (e) {
                                Swal.hideLoading();
                                Swal.update({
                                    icon: 'error',
                                    title: "Server is not healthy",
                                })
                            }
                        });
                    }
                });                
            });              
        }

        @foreach (var server in Model.Servers)
        {
            if (Model.Applications.Any(x => x.ServerID == server.ID))
            {
                foreach (var app in Model.Applications.Where(x => x.ServerID == server.ID))
                {
                    <text>
                        loadApplicationStorageUsed(@app.ID, '@app.Token', '@app.Server.ServerUrl');
                        bindExportBtn('@app.Token', '@app.Server.ServerUrl');
                        bindCompareBtn('@app.Token', '@app.Name');
                    </text>
                }
            }

            <text>
                setInterval(function(){
                    healthCheckServer(@server.ID, '@server.ServerUrl.Trim('/')');
                }, 5000);
                healthCheckServer(@server.ID, '@server.ServerUrl.Trim('/')');
            </text>
        }

        bindServerHealthLink();
    </script>
}