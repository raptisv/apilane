{
  "Environment": "Production",
  "Url": "http://localhost:5001",
  "InstallationKey": "c1aaa1e9-d8fc-4302-a217-9fd6cf25fdd5",
  "FilesPath": "C:\\src\\Apilane\\DatabaseFiles\\Files",
  "FileStorage": {
    "Provider": "LocalFileSystem"
    // --- Cloud Storage Provider Examples (uncomment and configure to use) ---
    //
    // Google Cloud Storage:
    // "Provider": "GoogleCloudStorage",
    // "ConnectionString": "/run/secrets/gcs-sa.json",  // Path to service account JSON
    // "BucketName": "my-app-files-bucket"
    //
    // AWS S3 or S3-compatible (e.g., Backblaze B2):
    // "Provider": "AwsS3",
    // "ConnectionString": "AccessKey=AKIA...;SecretKey=...;Region=us-east-1",
    // "BucketName": "my-app-files-bucket"
    //
    // Azure Blob Storage:
    // "Provider": "AzureBlobStorage",
    // "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net",
    // "BucketName": "my-container-name"  // Container name
  },
  "PortalUrl": "http://localhost:5000",
  "MinThreads": 50,
  "Clustering": {
    "ClusterId": "apilane_api_cluster",
    "ServiceId": "apilane_api_service",
    "Type": "Localhost",
    "SiloPort": 11111,
    "GatewayPort": 30000,
    "DashboardPort": 8080
  },
  "OpenTelemetry": {
    "Metrics": {
      "Enabled": true
    },
    "Tracing": {
      "Enabled": false,
      "Url": "http://localhost:4317",
      "SampleRatio": 0.25
    }
  },
  "InvalidFilesExtentions": [ ".exe", ".vbs", ".msi", ".jar", ".bat", ".cmd", ".vbe", ".js", ".jsp", ".lnk" ],
  "Serilog": {
    "WriteTo": [
      {
        "Name": "Graylog",
        "Args": {
          "facility": "Apilane.Api",
          "hostnameOrAddress": "127.0.0.1",
          "port": 12201,
          "transportType": "Udp",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss}] [{Level:u4}] [Process:{ProcessId,3:0} ({ProcessName})] [Assembly:{AssemblyVersion}] [Memory:{MemoryUsage}] [Thread:{ThreadId,3:0}] [{MachineName}] [{RequestId}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Warning"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessName"
    ],
    "Using": [ "Serilog.Expressions" ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath IN ['/metrics', '/health/liveness', '/health/readiness'] AND StatusCode = 200"
        }
      }
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Serilog.AspNetCore.RequestLoggingMiddleware": "Warning",
        "Microsoft.AspNetCore.Authorization.DefaultAuthorizationService": "Warning",
        "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Mvc.Internal": "Warning",
        "Microsoft.AspNetCore.Mvc": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Microsoft.AspNetCore.Cors.Infrastructure.CorsService": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
      }
    }
  }
}
